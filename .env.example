NEXT_PUBLIC_SITE_URL=https://owneronetool.com
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_XXXXXX
TOSS_SECRET_KEY=test_sk_XXXXXX
OPENAI_API_KEY=sk-XXXXXX
NEXT_PUBLIC_GOOGLE_VERIFICATION=구글서치콘솔_인증코드
NEXT_PUBLIC_NAVER_VERIFICATION=네이버서치어드바이저_인증코드

# DB (Supabase PostgreSQL 예시)
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=32자이상_랜덤_시크릿_문자열

# Rate Limiting (Upstash Redis) — 프로덕션 권장. 없으면 한도 검사 생략
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ——— 알림 (이메일 / 푸시 / 알림톡) ———
# 이메일: Resend (사장님 새 예약 알림)
RESEND_API_KEY=
RESEND_FROM=OWNER ONE-TOOL <onboarding@resend.dev>
NOTIFICATION_EMAIL=사장님_수신_이메일
# slug별 수신: NOTIFICATION_EMAIL_<SLUG대문자> (예: NOTIFICATION_EMAIL_MYSHOP)

# 브라우저 푸시: VAPID 키 (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# 카카오 알림톡 (고객 예약 확인/리마인드, 비즈 채널 연동 시)
# KAKAO_ALIMTALK_SENDER_KEY=
# KAKAO_ALIMTALK_CHANNEL_KEY=
# KAKAO_ALIMTALK_TEMPLATE_CODE=

# ——— Sentry (에러·성능 모니터링) ———
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ——— 카카오 로그인 (개발자 콘솔에서 발급) ———
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 네이버 로그인 (선택)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
