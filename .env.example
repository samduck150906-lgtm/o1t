# Supabase (제안서 랜딩 페이지 등)
# 대시보드: https://supabase.com/dashboard/project/YOUR_PROJECT_REF
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# 토스페이먼츠 결제위젯 시크릿 키 (live_gsk_...)
# 개발자센터 API 키 메뉴에서 확인 후 복사하세요. 반드시 서버에만 두고 노출하지 마세요.
TOSS_SECRET_KEY=live_gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# 서버 포트 (선택)
# PORT=3000

# 상담/문의 수신: ceo@eternalsix.com (mailto 사용 시 참고, resend.com API 키는 선택)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# 발신 주소 커스텀 (선택, 없으면 Resend 기본 발신 사용)
# RESEND_FROM=OWNER ONE-TOOL <noreply@yourdomain.com>
